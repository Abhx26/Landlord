# Database
DATABASE_URL="mongodb+srv://username:password@cluster.mongodb.net/landlord_db?retryWrites=true&w=majority"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-hex-32"

# Nodemailer SMTP (Gmail)
EMAIL_USER="your-email@gmail.com"
EMAIL_PASSWORD="your-app-specific-password-from-gmail"
EMAIL_FROM="noreply@yourdomain.com"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"
